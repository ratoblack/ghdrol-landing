# --- Pagou API v2 (Pix na própria loja) ---
# Token Bearer (sandbox ou produção). Nunca exponha no browser.
# @see https://developer.pagou.ai/start-here/authentication
PAGOU_API_KEY=

# sandbox (default) | production — tem de coincidir com o tipo de token (sandbox vs live).
PAGOU_ENV=sandbox

# URL pública do site (notify_url → …/api/webhooks/pagou).
# Em produção na Vercel:
# - Project → Settings → Environment Variables → marca Production (e Preview se precisares).
# - Nomes EXATOS: PAGOU_API_KEY, PAGOU_ENV, NEXT_PUBLIC_APP_URL (sem espaços à volta).
# - Depois de guardar: faz Redeploy (Deployments → ⋮ → Redeploy) ou novo push — senão o runtime pode ficar sem as vars novas.
# Ex.: NEXT_PUBLIC_APP_URL=https://teu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=

# Opcional (só servidor): URL canónica se não quiseres NEXT_PUBLIC_* (ex. domínio definitivo)
# PAGOU_PUBLIC_BASE_URL=https://teu-dominio.com.br

# --- Opcional: diagnóstico se create Pix falhar (omitir notify_url na Pagou) ---
# PAGOU_OMIT_NOTIFY_URL=1

# --- Opcional: persistir pedidos pending/pago e deduplicar webhooks (Upstash Redis grátis) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Fallback: links de checkout hospedados (sem API) ---
# PAGOU_CHECKOUT_1_UNIT_URL=
# PAGOU_CHECKOUT_2_UNIT_URL=
# PAGOU_CHECKOUT_3_UNIT_URL=
# PAGOU_CHECKOUT_5_UNIT_URL=
