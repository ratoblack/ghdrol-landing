# --- Pagou API v2 (Pix na própria loja) ---
# Token Bearer (sandbox ou produção). Nunca exponha no browser.
# @see https://developer.pagou.ai/start-here/authentication
PAGOU_API_KEY=

# sandbox (default) | production
PAGOU_ENV=sandbox

# URL pública do site (notify_url → …/api/webhooks/pagou). Define na Vercel para produção.
# Ex.: NEXT_PUBLIC_APP_URL=https://ghdrol-landing.vercel.app
NEXT_PUBLIC_APP_URL=

# Webhook HTTP (se a Pagou pedir URL fixa no painel, usa a mesma rota):
# https://SEU_DOMINIO/api/webhooks/pagou

# --- Opcional: persistir pedidos pending/pago e deduplicar webhooks (Upstash Redis grátis) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Fallback: links de checkout hospedados (sem API) ---
# PAGOU_CHECKOUT_1_UNIT_URL=
# PAGOU_CHECKOUT_2_UNIT_URL=
# PAGOU_CHECKOUT_3_UNIT_URL=
# PAGOU_CHECKOUT_5_UNIT_URL=
